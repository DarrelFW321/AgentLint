      "type": "tool_call",
      "sequence": 2,
      "tool_name": "send_email",
      "arguments": {
        "recipient": "customer@example.com",
        "body": "Your case has been updated."
      }
    }
  ],
  "edges": [
    {
      "id": "edge_data_public_to_email",
